# Скопируй в .env и заполни под своё окружение

# ── Сервис ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info

# Shared secret между .NET и Python. Должен совпадать в обоих сервисах.
INTERNAL_TOKEN=change-me-in-production

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET=soundwave
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_ENDPOINT_URL=http://localhost:9000   # или https://s3.amazonaws.com для AWS
S3_FORCE_PATH_STYLE=true               # true для MinIO, false для AWS

# ── .NET callback ─────────────────────────────────────────────────────────────
DOTNET_BASE_URL=http://localhost:5000
DOTNET_CALLBACK_PATH=/api/internal/tracks/{track_id}/processed

# ── ML ────────────────────────────────────────────────────────────────────────
EMBEDDING_SIZE=256
N_MELS=128
TARGET_SR=22050
DEVICE=cpu   # или "cuda" если есть GPU
